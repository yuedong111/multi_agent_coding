{
  "defaults": {
    "base_url": "https://api.openai.com/v1",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-4.1-mini",
    "temperature": 0.2,
    "max_steps": 12
  },
  "agents": {
    "lead": {
      "model": "gpt-4.1",
      "role": "负责澄清目标、拆解任务图、协调其他 agent，并决定什么时候完成。",
      "skills": ["vibe-coding", "task-graph"]
    },
    "architect": {
      "model": "gpt-4.1",
      "role": "负责项目结构、模块边界、接口契约、文件职责。",
      "skills": ["vibe-coding"]
    },
    "coder": {
      "model": "gpt-4.1",
      "role": "负责最小必要代码实现，严格按计划创建和修改文件。",
      "skills": ["vibe-coding", "codex-style"]
    },
    "tester": {
      "model": "gpt-4.1-mini",
      "role": "负责补测试、运行验证命令、根据失败日志提出修复。",
      "skills": ["testing"]
    },
    "reviewer": {
      "model": "gpt-4.1-mini",
      "role": "负责代码审查，优先找 bug、回归风险、缺失测试。",
      "skills": ["code-review"]
    },
    "release": {
      "model": "gpt-4.1-mini",
      "role": "负责 README、运行说明、部署清单、上线风险说明。",
      "skills": ["release"]
    }
  }
}
